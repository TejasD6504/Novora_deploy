  console.log("Extracted pickup number:", pickupNum);
  console.log("Extracted destination number:", destinationNum);

  // if (destinationNum) path2Mapped.push(destinationNum);
  // path3Mapped.push("1"); 

  const directionMap = {
    "up": "straight",
    "down": "back",
    "left": "left",
