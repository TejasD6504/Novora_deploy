  </div>

  <script>
const canvas = document.getElementById("mapCanvas");
const ctx = canvas.getContext("2d");
const loadingIndicator = document.getElementById("loadingIndicator");
const calculateBtn = document.getElementById("calculateBtn");
const statsContent = document.getElementById("statsContent");
const noStats = document.getElementById("noStats");

const rows = 2;
const cols = 3;
let smallBoxRows = 2;
let smallBoxCols = 3;
const cellSizeCols = (canvas.width - 100) / cols;
const cellSizeRows = (canvas.height - 100) / rows;
const nodes = {};
const padding = 50;

let pickupLabel = null;
let destinationLabel = null;
let occupiedplaceslabel = [];
let unoccupied_Racks = [];

let pathStats = {
  totalSteps: 0,
  nodesVisited: 0
};

function drawGrid() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  ctx.strokeStyle = "#e9ecef";
  ctx.lineWidth = 1;

  for (let r = 0; r <= rows; r++) {
    ctx.beginPath();
    ctx.moveTo(50, r * cellSizeRows + padding);
    ctx.lineTo(canvas.width - 50, r * cellSizeRows + padding);
    ctx.stroke();
  }

  for (let c = 0; c <= cols; c++) {
    ctx.beginPath();
    ctx.moveTo(c * cellSizeCols + padding, 50);
    ctx.lineTo(c * cellSizeCols + padding, canvas.height - 50);
    ctx.stroke();
  }

  let letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
  let nodeGrid = [];
  let counter = 0;
  for (let r = 0; r < rows + 1; r++) {
    let row = [];
    for (let c = 0; c < cols + 1; c++) {
      row.push(letters[counter++]);
    }
    nodeGrid.push(row);
  }

  let prefixCounts = {};

  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      let startX = c * cellSizeCols + padding;
      let startY = r * cellSizeRows + padding;
      let brBottom = rows - 1 - r;

      let boxWidth = cellSizeCols / smallBoxCols - 10;
      let boxHeight = cellSizeRows / smallBoxRows - 10;

      for (let i = 0; i < smallBoxRows; i++) {
        for (let j = 0; j < smallBoxCols; j++) {
          let x = startX + j * (boxWidth + 5) + 10;
          let y = startY + i * (boxHeight - 20) + 30;

          let prefix;
          if (i === 0) {
            prefix = nodeGrid[brBottom + 1][c + 1];
          } else if (r === rows - 1) {
            prefix = nodeGrid[0][c];
          } else {
            prefix = nodeGrid[brBottom][c + 1];
          }

          let num = (prefixCounts[prefix] || 0) + 1;
          prefixCounts[prefix] = num;

          let label = prefix + num;

          let fillColor;

          if (label === pickupLabel) {
            fillColor = "rgba(76, 175, 80, 0.7)";
          } else if (label === destinationLabel) {
            fillColor = "rgba(255, 193, 7, 0.7)";
          } else if (occupiedplaceslabel.includes(label)) {
            fillColor = "rgba(255, 53, 69, 0.3)";
          } else if(unoccupied_Racks.includes(label)){
            fillColor = "rgba(108, 117, 125, 0.3)";
          } else {
            const gradient = ctx.createLinearGradient(x, y, x + boxWidth, y + boxHeight - 30);
            gradient.addColorStop(0, '#f8f9fa');
            gradient.addColorStop(1, '#e9ecef');
            fillColor = gradient;
          }

          ctx.fillStyle = fillColor;
          ctx.fillRect(x, y, boxWidth, boxHeight - 30);

          ctx.strokeStyle = "#adb5bd";
          ctx.lineWidth = 1.5;
          ctx.strokeRect(x, y, boxWidth, boxHeight - 30);

          ctx.fillStyle = "#495057";
          ctx.font = "bold 11px system-ui";
          ctx.textAlign = "center";
          ctx.fillText(label, x + boxWidth / 2, y + (boxHeight - 30) / 2 + 4);
        }
      }
    }
  }
}

function setPickup(label) {
  pickupLabel = label;
  drawGrid();
}

function setoccupied_places(label) {
  if (!occupiedplaceslabel.includes(label)) {
    occupiedplaceslabel.push(label);
  }
  drawGrid();
}

function unoccupied_places(label) {
  if (!unoccupied_Racks.includes(label)) {
    unoccupied_Racks.push(label);
  }
  drawGrid();
}

function setDestination(label) {
  destinationLabel = label;
  drawGrid();
}

function createNodes() {
  let id = 0;
  for (let ri = rows; ri >= 0; ri--) { 
    for (let c = 0; c <= cols; c++) {
      const x = c * cellSizeCols + padding;
      const y = ri * cellSizeRows + padding;
      const name = String.fromCharCode(65 + id++); 
      const r = rows - ri; 
      nodes[name] = {x, y, r , c, name};

      const gradient = ctx.createRadialGradient(x, y, 2, x, y, 8);
      gradient.addColorStop(0, '#dc2626');
      gradient.addColorStop(1, '#b91c1c');

      ctx.beginPath();
      ctx.arc(x, y, 8, 0, 2 * Math.PI);
      ctx.fillStyle = gradient;
      ctx.fill();
      
      ctx.strokeStyle = "#ffffff";
      ctx.lineWidth = 3;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(x - 2, y - 2, 2, 0, 2 * Math.PI);
      ctx.fillStyle = "rgba(255, 255, 255, 0.6)";
      ctx.fill();

      ctx.fillStyle = "#1f2937";
      ctx.font = "bold 13px system-ui";
      ctx.textAlign = "center";
   
      ctx.fillStyle = "rgba(255, 255, 255, 0.8)";
      ctx.fillText(name, x + 16, y - 9);
      ctx.fillStyle = "#1f2937";
      ctx.fillText(name, x + 15, y - 10);
    }
  }
}

function bfs(start, end) {
  let queue = [[start]];
  let dirQueue = [[]];
  let visited = new Set([start]);
  let nodesExplored = 0;

  while (queue.length) {
    let path = queue.shift();
    let dirs = dirQueue.shift();
    let node = path[path.length - 1];

    nodesExplored++;

    if (node === end) {
      pathStats.nodesVisited += nodesExplored;
      let lastNodeNeighbors = getNeighbors(node);

      if(end != "A"){
        for (let [nbr, direction] of lastNodeNeighbors) {
          if (direction === "left" || direction === "right") {
            path.push(nbr);
            dirs.push(direction);
            break; 
          }
        }
      }

      return { path, dirs };
    }

    for (let [neighbor, move] of getNeighbors(node)) {
      if (!visited.has(neighbor)) {
        visited.add(neighbor);
        queue.push([...path, neighbor]);
        dirQueue.push([...dirs, move]); 
      }
    }
  }

  return { path: [], dirs: [] };
}

function getNodeName(r, c) {
  return Object.values(nodes).find(n => n.r === r && n.c === c)?.name;
}

function getNeighbors(node) {
  const { r, c } = nodes[node];
  const neighbors = [];

  if (r === 0) {
    if (c === 0) {
      const right = getNodeName(r, c + 1);
      if (right) neighbors.push([right, "right"]);
    } else if (c > 0 && c < cols) {
      const right = getNodeName(r, c + 1);
      const up = getNodeName(r + 1, c);
      if (right) neighbors.push([right, "right"]);
      if (up) neighbors.push([up, "up"]);
    } else if (c === cols) {
      const up = getNodeName(r + 1, c);
      if (up) neighbors.push([up, "up"]);
    }
    return neighbors;
  }

  if (r === rows) {
    if (c === 0) {
      const down = getNodeName(r - 1, c);
      if (down) neighbors.push([down, "down"]);
    } else {
      const left = getNodeName(r, c - 1);
      if (left) neighbors.push([left, "left"]);
    }
    return neighbors;
  }

  if (c === 0 && r > 0 && r < rows) {
    const down = getNodeName(r - 1, c);
    if (down) neighbors.push([down, "down"]);
    return neighbors;
  }

  if (c === cols && r > 0 && r < rows) {
    const up = getNodeName(r + 1, c);
    const left = getNodeName(r, c - 1);
    if (up) neighbors.push([up, "up"]);
    if (left) neighbors.push([left, "left"]);
    return neighbors;
  }

  if (r > 0 && r < rows && c > 0 && c < cols) {
    const up = getNodeName(r + 1, c);
    const left = getNodeName(r, c - 1);
    if (up) neighbors.push([up, "up"]);
    if (left) neighbors.push([left, "left"]);
    return neighbors;
  }

  return neighbors;
}

// ======================
// Draw Mini Custom Line
// ======================
function drawCustomLine(x1, y1, x2, y2, color = "#28a745", width = 4) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = width;
    ctx.lineCap = "round";

    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.stroke();
}

// Get approximate box center for a rack label like 'C1'
function getBoxForLabel(label) {
  if (!label) return null;
  const letter = label.charAt(0);
  const num = parseInt(label.slice(1), 10);
  if (isNaN(num)) return null;

  const first = nodes[letter];
  if (!first) return null;

  const boxW = cellSizeCols / smallBoxCols - 10;
  const boxH = cellSizeRows / smallBoxRows - 10;

  let midX = 0;
  let yPos = first.y;

  const letterIndex = letter.charCodeAt(0) - 65;

  // Upper shelves (1..smallBoxCols)
  if (num <= smallBoxCols) {
    if (letterIndex <= cols) {
      midX = first.x + (num - 1) * (boxW + 5) + 10 + boxW / 2;
      yPos = first.y;
    } else if (letterIndex >= (rows * cols + smallBoxCols * smallBoxRows - cols - 1)) {
      let mapped = (cols + 1) - num;
      midX = first.x - (mapped - 1) * (boxW + 5) - 10 - boxW / 2;
      yPos = first.y + 40;
    } else if (letterIndex > cols) {
      let mapped = (cols + 1) - num;
      midX = first.x - (mapped - 1) * (boxW + 5) - 10 - boxW / 2;
      yPos = first.y;
    }
  } else {
    // Lower shelves (> smallBoxCols)
    if (letterIndex > cols) {
      let mapped = (smallBoxRows * smallBoxCols + 1) - num;
      midX = first.x - (mapped - 1) * (boxW + 5) - 10 - boxW / 2;
      yPos = first.y + 40;
    }
  }

  return { x: midX, y: yPos };
}

function drawCustomLineOnRack(label, color = '#28a745', length = 36, width = 6) {
  const box = getBoxForLabel(label);
  if (!box) return;
  // draw a short vertical pointer from box center upward
  const startX = box.x;
  const startY = box.y;
  drawCustomLine(startX, startY, startX, startY - length, color, width);
}

function drawPath(path, color, width = 5, offset = 0, customnode = null) {
  if (!Array.isArray(path) || path.length === 0) return;

  ctx.beginPath();
  const start = nodes[path[0]];
  const end = nodes[path[path.length - 1]];

  // prevent zero-length gradient
  const gx2 = (end.x === start.x && end.y === start.y) ? end.x + 1 : end.x;
  const gy2 = (end.y === start.y && end.x === start.x) ? end.y + 1 : end.y;

  const gradient = ctx.createLinearGradient(start.x, start.y, gx2, gy2);
  if (color === "#007bff") {
    gradient.addColorStop(0, '#007bff');
    gradient.addColorStop(1, '#0056b3');
  } else if (color === "#28a745") {
    gradient.addColorStop(0, '#28a745');
    gradient.addColorStop(1, '#1e7e34');
  } else if (color === "#fd7e14") {
    gradient.addColorStop(0, '#fd7e14');
    gradient.addColorStop(1, '#dc3545');
  } else {
    gradient.addColorStop(0, color);
    gradient.addColorStop(1, color);
  }

  ctx.strokeStyle = gradient;
  ctx.lineWidth = width;
  ctx.lineCap = "round";
  ctx.lineJoin = "round";

  // shadow
  ctx.shadowColor = "rgba(0, 0, 0, 0.3)";
  ctx.shadowBlur = 4;
  ctx.shadowOffsetX = 2;
  ctx.shadowOffsetY = 2;

  let startNode = nodes[path[0]];
  ctx.moveTo(startNode.x + offset, startNode.y + offset);
  for (let i = 1; i < path.length; i++) {
    let pos = nodes[path[i]];
    ctx.lineTo(pos.x + offset, pos.y + offset);
  }
  ctx.stroke();

  // reset shadow
  ctx.shadowColor = "transparent";
  ctx.shadowBlur = 0;
  ctx.shadowOffsetX = 0;
  ctx.shadowOffsetY = 0;

  // draw endpoint indicator when customnode provided
  if (customnode) {
    try {
      drawCustomLineOnRack(customnode, color, 36, Math.max(4, width));
    } catch (e) {
      console.warn('drawPath: failed to draw custom indicator', e);
    }
  }
}

    function updateStats(result1, result2, result3) {
      const totalSteps = (result1.path.length - 1) + (result2.path.length - 1) + (result3.path.length - 1);
      
      document.getElementById("totalSteps").textContent = totalSteps;
      document.getElementById("nodesVisited").textContent = pathStats.nodesVisited;
      
      statsContent.style.display = "block";
      noStats.style.display = "none";
    }

    function showValidationError(message) {
      const existingAlert = document.querySelector('.alert');
      if (existingAlert) {
        existingAlert.remove();
      }

      const alert = document.createElement('div');
      alert.className = 'alert alert-warning';
      alert.textContent = message;
      
      document.querySelector('.control-section').insertBefore(
        alert, 
        document.querySelector('.form-grid')
      );

      setTimeout(() => {
        if (alert.parentNode) {
          alert.remove();
        }
      }, 5000);
    }

    // Store last calculated paths
let lastResults = { r1: null, r2: null, r3: null };

function showOnlyPath(pathNum) {
  const pickup = document.getElementById('pickup') ? document.getElementById('pickup').value : null;
  const destination = document.getElementById('destination') ? document.getElementById('destination').value : null;

  ctx.clearRect(0, 0, canvas.width, canvas.height);
  drawGrid();
  createNodes();

  if (!lastResults.r1 || !lastResults.r2 || !lastResults.r3) {
    console.warn("No paths calculated yet.");
    return;
  }

  if (pathNum === 1) {
    drawPath(lastResults.r1.path, "#007bff", 6, 0, pickup);
  } else if (pathNum === 2) {
    drawPath(lastResults.r2.path, "#28a745", 6, 0, destination);
  } else if (pathNum === 3) {
    drawPath(lastResults.r3.path, "#fd7e14", 6, 0, null);
  } else if (pathNum === 0) {
    // Show all
    drawPath(lastResults.r1.path, "#007bff", 6, 0, pickup);
    drawPath(lastResults.r2.path, "#28a745", 6, 0, destination);
    drawPath(lastResults.r3.path, "#fd7e14", 6, 0, null);
  }
}


    function drawFullPath() {
      const pickup = document.getElementById("pickup").value;       // e.g. "A1"
      const destination = document.getElementById("destination").value; // e.g. "B2"
      const pathOutput = document.getElementById("pathOutput");


      setPickup(pickup);
setDestination(destination);

      if (!pickup || !destination) {
        showValidationError("Please select both pickup and destination locations.");
        return;
      }

      if (pickup === destination) {
        showValidationError("Pickup and destination must be different locations.");
        return;
      }

      // Send the selected rack IDs (A1, B2, ...) to the server as requested
      fetch("/calculate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ pickuprack: pickup, destinationrack: destination })
      }).then(res => res.text()).then(console.log).catch(console.error);

      // Show loading state
      loadingIndicator.style.display = "block";
      calculateBtn.disabled = true;
      statsContent.style.display = "none";
      noStats.style.display = "block";

      // Reset stats
      pathStats = { totalSteps: 0, nodesVisited: 0 };

      setTimeout(() => {
        // Clear and redraw
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        drawGrid();
        createNodes();

        // For pathfinding use the rack letter only (A, B, ...) extracted from A1/A2
        const pickupLetter = pickup.charAt(0);
        const destinationLetter = destination.charAt(0);


        // Calculate paths
        let result1, result2, result3;

        result1 = bfs("A", pickupLetter);
        result2 = bfs(result1.path[result1.path.length - 1], destinationLetter); 
        result3 = bfs(result2.path[result2.path.length - 1], "A");


        // Save results globally
        lastResults.r1 = result1;
        lastResults.r2 = result2;
        lastResults.r3 = result3;

        // Avoid overlapping paths and draw indicators
        drawPath(result1.path, "#007bff", 6, -2, pickup);
        drawPath(result2.path, "#28a745", 6, 0, destination);
        drawPath(result3.path, "#fd7e14", 6, 2, null);

        // Update statistics
        updateStats(result1, result2, result3);

        // Hide loading state
        loadingIndicator.style.display = "none";
        calculateBtn.disabled = false;

        pathOutput.innerHTML = `
          <h3>🗺️ Calculated Paths</h3>
          <p><strong style="color: #007bff;">Path 1 (Start to Pickup):</strong> 
             <span class="path-segment">${result1.path.join(" → ")}</span>
             <small style="color: #6c757d;"> (${result1.path.length - 1} steps)</small>
          </p>
          <p><strong style="color: #28a745;">Path 2 (Pickup to Destination):</strong> 
             <span class="path-segment">${result2.path.join(" → ")}</span>
             <small style="color: #6c757d;"> (${result2.path.length - 1} steps)</small>
          </p>
          <p><strong style="color: #fd7e14;">Path 3 (Destination to Start):</strong> 
             <span class="path-segment">${result3.path.join(" → ")}</span>
             <small style="color: #6c757d;"> (${result3.path.length - 1} steps)</small>
          </p>
          <div style="margin-top: 20px; padding: 15px; background: rgba(102, 126, 234, 0.1); border-radius: 8px; border-left: 4px solid #667eea;">
            <strong>📊 Summary:</strong> Total journey requires ${(result1.path.length - 1) + (result2.path.length - 1) + (result3.path.length - 1)} steps across ${pathStats.nodesVisited} explored nodes.
          </div>
        `;

        // console.log("Calculated paths sent to Arduino.",pickup, destination);


      sendAllPathsToArduino(result1, result2, result3);


