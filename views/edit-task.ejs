    async function saveTask() {
      const pickup = document.getElementById("pickup").value;
      const destination = document.getElementById("destination").value;
      const saveBtn = document.getElementById('saveTaskBtn');

      if (!pickup || !destination) {
        showValidationError('Please select both pickup and destination before saving.');
        return;
      }

      if (pickup === destination) {
        showValidationError('Pickup and destination must be different to save a task.');
        return;
      }

      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      try {
        const res = await fetch('/update-task', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ task_id : `<%= task.task_id %>` , pickup, destination , status: "pending"})
        });

        if (!res.ok) {
          const txt = await res.text();
          throw new Error(txt || 'Server returned an error');
        }

        const data = await res.json();
        showSuccess(`Task saved (id: ${data.taskId || 'N/A'})`);
        console.log('Task save response:', data);
      } catch (err) {
        console.error('Save task failed:', err);
        showValidationError('Failed to save task: ' + (err.message || 'Unknown'));
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Task';
      }
    }

    function showSuccess(message) {
      const existing = document.querySelector('.alert');
      if (existing) existing.remove();

      const el = document.createElement('div');
      el.className = 'alert';
      el.style.background = 'linear-gradient(135deg, #d1fae5 0%, #b7f0d4 100%)';
      el.style.color = '#065f46';
      el.style.borderLeft = '4px solid #10b981';
      el.textContent = message;

      document.querySelector('.control-section').insertBefore(el, document.querySelector('.form-grid'));

      setTimeout(() => { if (el.parentNode) el.remove(); }, 5000);
    }

