  };

  // ✅ Convert direction names to Arduino-friendly words
  const path1Mapped = result1.dirs.map(d => directionMap[d] || d);
  const path2Mapped = result2.dirs.map(d => directionMap[d] || d);
  const path3Mapped = result3.dirs.map(d => directionMap[d] || d);

