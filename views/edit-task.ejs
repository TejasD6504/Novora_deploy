pickupSel.innerHTML = `<option value="<%= task.source_address %>">Rack <%= task.source_address %></option>`;
destSel.innerHTML = `<option value="<%= task.destination_address %>">Rack <%= task.destination_address %></option>`;

let count = cols;
let results = (rows * cols) + 3 * (cols - 1);

const rackNames = [];

// Generate rack names
for (let i = 0; i <= results; i++) {
  if (i === (results - cols)) count = cols;

  if ((i !== 0 && i % (cols + 1) === 0) || i === cols) continue;

  if (count !== 0) {
    for (let j = 0; j < smallBoxCols; j++) {
      rackNames.push(String.fromCharCode(65 + i) + (j + 1));
    }
    count--;
  } else {
    for (let j = 0; j < smallBoxRows * smallBoxCols; j++) {
      rackNames.push(String.fromCharCode(65 + i) + (j + 1));
    }
  }
}

console.log("Generated racks:", rackNames);

