<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Warehouse Dashboard</title>
  <style>
    :root {
      --primary: #00c6ff;
      --primary-dark: #0072ff;
      --success: #00e676;
      --background: #f4f6f9;
      --text-dark: #333;
      --text-light: #fff;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: var(--background);
      color: var(--text-dark);
      padding: 20px;
    }

    .dashboard {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .card {
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
      text-align: center;
    }

    .card h3 {
      font-size: 1.1rem;
      margin-bottom: 10px;
      color: #555;
    }

    .card p {
      font-size: 1.5rem;
      font-weight: bold;
      color: var(--primary-dark);
    }

    .bottom-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .slot-status, .rack-table {
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .slot-status h2, .rack-table h2 {
      margin-bottom: 15px;
      font-size: 1.3rem;
      color: var(--text-dark);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      padding: 12px 10px;
      text-align: left;
      border-bottom: 1px solid #e0e0e0;
    }

    th {
      background: #f0f2f5;
      color: #555;
    }

    tr:hover td {
      background: #f9f9f9;
    }

    .badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 12px;
      font-size: 1rem;
      color: #fff;
    }

    .occupied { background-color: rgb(0, 191, 255); color: white; }
    .empty { background-color: rgba(255, 0, 0, 0.552); color: white; }
    .ongoing { background-color: #ffc107; color: white; }
    .completed { background-color: var(--success); }

    @media (max-width: 768px) {
      .bottom-section {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="dashboard">

    <!-- Top Summary Cards -->
    <div class="cards">
      <div class="card">
        <h3>Total Products</h3>
        <p><%= summary?.totalProducts ?? 0 %></p>
      </div>
      <div class="card">
        <h3>Total Racks</h3>
        <p><%= summary?.totalRacks ?? 0 %></p>
      </div>
      <div class="card">
        <h3>Active Rovers</h3>
        <p><%= summary?.activeRovers ?? 0 %></p>
      </div>
      <div class="card">
        <h3>Pending Tasks</h3>
        <p><%= summary?.pendingTasks ?? 0 %></p>
      </div>
    </div>

    <!-- Bottom Tables -->
    <div class="bottom-section">
      <!-- Storage Slot Status -->
      <div class="slot-status">
        <h2>Storage Slot Status</h2>
        <table>
          <thead>
            <tr>
              <th>Rack ID</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% slots.forEach(function(s) { %>
            <tr>
              <td><%= s.rack_id %></td>
              <td>
                <% if (s.status.toLowerCase() === 'occupied') { %>
                  <span class="badge occupied">Occupied</span>
                <% } else if (s.status.toLowerCase() === 'empty') { %>
                  <span class="badge empty">Empty</span>
                <% } else { %>
                  <span class="badge"><%= s.status %></span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Latest Tasks -->
      <div class="rack-table">
        <h2>Latest Tasks</h2>
        <table>
          <thead>
            <tr>
              <th>Task ID</th>
              <th>Type</th>
              <th>Source</th>
              <th>Destination</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% tasks.forEach(function(t) { %>
            <tr>
              <td><%= t.id %></td>
              <td><%= t.type %></td>
              <td><%= t.source %></td>
              <td><%= t.destination %></td>
              <td>
                <% if (t.status.toLowerCase() === 'ongoing') { %>
                  <span class="badge ongoing">Ongoing</span>
                <% } else if (t.status.toLowerCase() === 'completed') { %>
                  <span class="badge completed">Completed</span>
                <% } else { %>
                  <span class="badge"><%= t.status %></span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</body>
</html>
